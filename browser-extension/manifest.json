{
  "manifest_version": 3,
  "name": "Zettel Save",
  "version": "1.0",
  "description": "Speichere Links, Bilder und Dateien direkt zu Zettel",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zu Zettel speichern",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://ankerkladde.benduhn.de/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "http://[::1]:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
