{
  "manifest_version": 3,
  "name": "Ankerkladde",
  "version": "5.0.0",
  "description": "Speichere Links, Bilder und Dateien direkt zu Ankerkladde",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zu Ankerkladde speichern",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ankerkladde.benduhn.de/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "http://[::1]:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],
  "omnibox": {
    "keyword": "ak"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Aktuelle Seite in Ankerkladde speichern"
    }
  }
}
