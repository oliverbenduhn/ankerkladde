{
  "manifest_version": 3,
  "name": "Ankerkladde",
  "version": "4.2.2",
  "description": "Speichere Links, Bilder und Dateien direkt zu Ankerkladde",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zu Ankerkladde speichern",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ankerkladde.benduhn.de/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "http://[::1]:*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ankerkladde@benduhn.de",
      "strict_min_version": "109.0"
    }
  }
}
